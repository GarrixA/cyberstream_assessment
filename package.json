{
	"name": "cyberstream",
	"version": "1.0.0",
	"description": "CyberStream backend API",
	"main": "index.js",
	"scripts": {
		"dev": "ts-node-dev --require dotenv/config src/index.ts",
		"build": "tsc",
		"start": "node --require dotenv/config dist/index.js",
		"migrate": "npx sequelize-cli db:migrate",
		"migrate:reset": "npx sequelize-cli db:migrate:undo:all && npm run migrate && npm run seed",
		"migrate:down": "npx sequelize-cli db:migrate:undo:all",
		"migrate:undo": "npx sequelize-cli db:migrate:undo",
		"seed": "npx sequelize-cli db:seed:all",
		"seed:undo": "npx sequelize-cli db:seed:undo:all",
		"lint": "eslint .",
		"beauty": "prettier . --write",
		"check": "prettier . --check",
		"prepare": "husky",
		"precommit": "prettier . --write && eslint --fix .",
		"run-tests": "cross-env NODE_ENV=test jest --detectOpenHandles --coverage --verbose --testTimeout=10000",
		"pretest": "cross-env NODE_ENV=test npm run migrate:reset",
		"run-after-tests": "cross-env NODE_ENV=test sequelize db:migrate:undo:all",
		"test": "npm-run-all run-tests run-after-tests --continue-on-error"
	},
	"keywords": [],
	"license": "ISC",
	"dependencies": {
		"bcrypt": "^6.0.0",
		"cors": "^2.8.5",
		"cross-env": "^7.0.3",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"joi": "^18.2.3",
		"jsonwebtoken": "^9.0.3",
		"nodemailer": "^9.0.1",
		"npm-run-all": "^4.1.5",
		"pg": "^8.11.5",
		"pg-hstore": "^2.3.4",
		"sequelize": "^6.37.3",
		"uuid": "^14.0.1"
	},
	"jest": {
		"preset": "ts-jest",
		"setupFiles": [
			"<rootDir>/jest.setup.ts"
		],
		"maxWorkers": 1,
		"testEnvironment": "node",
		"testPathIgnorePatterns": [
			"/node_modules/",
			"/dist/"
		],
		"coverageReporters": [
			"json-summary",
			"text",
			"lcov"
		],
		"coveragePathIgnorePatterns": [
			"/src/database/config",
			"src/documention/index.ts",
			"/src/utils"
		]
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.12",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^20.12.12",
		"@types/nodemailer": "^8.0.1",
		"@types/supertest": "^6.0.2",
		"@types/uuid": "^10.0.0",
		"eslint": "^8.57.0",
		"husky": "^9.0.11",
		"jest": "^29.7.0",
		"lint-staged": "^15.2.2",
		"prettier": "3.2.5",
		"sequelize-cli": "^6.6.2",
		"supertest": "^6.3.4",
		"swagger-ui-express": "^5.0.0",
		"ts-jest": "^29.1.2",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.4.5",
		"typescript-eslint": "^7.7.0"
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --fix",
			"prettier --ignore-unknown --write",
			"git add"
		]
	},
	"overrides": {
		"@types/express": "^4.17.21"
	}
}
